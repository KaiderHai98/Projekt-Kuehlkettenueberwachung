# ===========================================================================
# Doxyfile für Projekt-Kuehlkettenueberwachung
# Dokumentiert Phase 1 und Phase 2 gemeinsam
# ===========================================================================

PROJECT_NAME           = "Projekt-Kuehlkettenueberwachung"
PROJECT_BRIEF          = "Dokumentation der Kuehlkettenueberwachung aus Phase 1 und Phase 2"
OUTPUT_LANGUAGE        = German
OUTPUT_DIRECTORY       = docs

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES

INPUT                  = .
RECURSIVE              = YES
FILE_PATTERNS          = *.py *.md
EXCLUDE_PATTERNS       = */__pycache__/* */Tests/* */.venv/* */.env/* */docs/*
USE_MDFILE_AS_MAINPAGE = README
MARKDOWN_SUPPORT       = YES

EXTENSION_MAPPING      = py=Python
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
PYTHON_DOCSTRING       = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_UNDOC_RELATIONS   = NO
SHOW_FILES             = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES
QUIET                  = NO
WARN_LOGFILE           = docs/doxygen_warnings.txt

HAVE_DOT               = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

DOXYFILE_ENCODING      = UTF-8

# ===========================================================================
# Ende der Konfiguration
# ===========================================================================